#!/usr/bin/env bash
set -euo pipefail

remote_name="${1:-}"
zero_sha="0000000000000000000000000000000000000000"

while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$local_sha" == "$zero_sha" ]]; then
    continue
  fi
  if [[ "$remote_ref" == refs/heads/* \
    && "$remote_ref" != "refs/heads/dev" \
    && !( "$remote_name" == "origin" && "$remote_ref" == "refs/heads/main" ) ]]; then
    echo "Push rejected: use dev, or owner-authorized origin/main for Pages." >&2
    exit 1
  fi
done

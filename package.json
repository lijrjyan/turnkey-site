{
  "name": "turnkey-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "test": "node --test tests/*.test.mjs",
    "test:e2e": "playwright test",
    "check": "pnpm test && astro check",
    "verify": "pnpm test && pnpm notebooks:check && pnpm build && pnpm test:e2e && pnpm audit --audit-level high",
    "notebooks:sync": "node scripts/sync-notebooks.mjs",
    "notebooks:check": "node scripts/sync-notebooks.mjs --check"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "7.2.1",
    "@astrojs/starlight": "0.41.4",
    "astro": "7.1.3",
    "sharp": "0.35.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@astrojs/check": "0.9.6",
    "@playwright/test": "1.59.0",
    "typescript": "5.9.3"
  }
}
